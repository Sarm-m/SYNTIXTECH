MONGO_URI=mongodb://mongodb:27017/logistica_db
DOCKER_MONGO_URI=mongodb://mongodb:27017/logistica_db
PORT=5000
JWT_SECRET=change-me-local-jwt-secret
CORS_ORIGIN=http://localhost:3000

GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
VITE_API_URL=/api
VITE_ENABLE_LOCAL_AUTH_FALLBACK=false

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-app-password

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000

WEBOTP_DOMAIN=localhost
OTP_EXPIRACION_MINUTOS=10
OTP_MAX_INTENTOS=5
OTP_COOLDOWN_SEGUNDOS=60

BACKEND_IMAGE=your-dockerhub-user/drivectrl-backend
FRONTEND_IMAGE=your-dockerhub-user/drivectrl-frontend
IMAGE_TAG=latest
