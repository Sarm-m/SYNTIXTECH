# Frontend local environment example for `npm run dev`.
# Copy to apps/web/.env.local and keep only public VITE_* values here.
# Do not put backend secrets or real credentials in frontend env files.

VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=<google-client-id>
VITE_ENABLE_LOCAL_AUTH_FALLBACK=false
