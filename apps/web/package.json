{
  "name": "web",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-dev.mjs",
    "dev": "concurrently \"npm --prefix ../../backend start\" \"vite --host :: --port 3000\"",
    "dev:frontend": "vite --host :: --port 3000",
    "backend": "npm --prefix ../../backend start",
    "build": "node tools/generate-llms.js && vite build --outDir ../../dist/apps/web --emptyOutDir",
    "start": "vite preview --outDir ../../dist/apps/web --host :: --port 3000",
    "lint": "eslint . --quiet",
    "lint:warn": "eslint .",
    "quality:metrics": "node tools/generate-quality-evidence.mjs",
    "test": "vitest run --coverage.enabled=true --coverage.reporter=text --coverage.reporter=lcovonly --coverage.reporter=html",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "axios": "^1.17.0",
    "lucide-react": "^0.469.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^6.30.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "terser": "^5.37.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
